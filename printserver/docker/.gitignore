dist/
build/
.next/
out/

# Logs
logs/
*.log
npm-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Temporary files
tmp/
temp/
*.tmp

# TypeScript cache
*.tsbuildinfo