# Ignore node_modules
node_modules/
.npm*

# Ignore Next.js build artifacts
.next/
out/
build/

# Ignore environment files
.env
.env.*
!.env.example
!.env.local

# Ignore IDE dan editor
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore git
.git/
.gitignore

# Ignore logs
logs/
*.log
npm-debug.log*

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test files
**/*.test.js
**/*.test.tsx
**/*.spec.js
coverage/

# Ignore temporary files
tmp/
temp/
*.tmp

# Ignore TypeScript cache
*.tsbuildinfo