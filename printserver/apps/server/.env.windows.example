# ============================================
# PrintServer Pro - Windows Node Configuration
# ============================================
# Copy file ini ke C:\PrintServer\config\.env di Windows Server
# atau set Environment Variables di Windows System Properties

# ============================================
# SERVER MODE - WAJIB DIISI
# ============================================
IS_NODE=true
IS_CENTRAL=false

# Nama node untuk identifikasi di Dashboard
NODE_NAME=NODE-OFFICE-01

# Node ID (akan di-set oleh Central Hub saat registrasi pertama)
NODE_ID=

# ============================================
# CENTRAL HUB CONNECTION
# ============================================
# GANTI dengan IP atau hostname Ubuntu server Anda
CENTRAL_HUB_URL=http://192.168.1.50:3000

# Shared Secret - HARUS SAMA dengan yang di Central Hub
NODE_SECRET=rahasia-perusahaan-anda-ganti-dengan-secret-yang-aman

# ============================================
# WINDOWS NODE CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (Windows Node tidak perlu database lokal)
# Jika ingin pakai SQLite lokal, bisa aktifkan:
# DATABASE_URL=sqlite://C:\PrintServer\data\node.db

# Redis (tidak perlu di Windows Node, hanya untuk Central Hub)
# REDIS_URL=redis://192.168.1.50:6379

# JWT (hanya untuk auth lokal, tidak perlu di Windows Node)
# JWT_SECRET=local-secret-key

# ============================================
# PRINT SPOOL DIRECTORY
# ============================================
# Direktori temporary untuk file print
SPOOL_DIR=C:\PrintServer\Spool

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_PRETTY=false

# ============================================
# FIREWALL (OPSIONAL - untuk debugging)
# ============================================
# Jika ingin akses remote untuk debugging:
# ALLOW_REMOTE_DEBUG=true
# DEBUG_PORT=9229

# ============================================
# MONITORING
# ============================================
# Kirim metrics ke Central Hub (metrics belum aktif)
# SEND_METRICS=true
# METRICS_INTERVAL=60000

# ============================================
# NOTES:
# ============================================
# 1. Pastikan Windows Firewall mengizinkan inbound port 3000 dari IP Ubuntu
# 2. Untuk production, gunakan HTTPS dengan reverse proxy (nginx)
# 3. NODE_SECRET harus sama persis dengan Central Hub
# 4. Jalankan sebagai Service dengan: nssm install PrintServerNode
# ============================================
