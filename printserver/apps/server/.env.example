# ============================================
# PrintServer Pro - Server Configuration
# ============================================
# Untuk single server (Ubuntu/Docker Central Hub), IS_NODE=false dan IS_CENTRAL=true
# Untuk Windows Node, IS_NODE=true dan IS_CENTRAL=false

# Server Mode
IS_NODE=false
IS_CENTRAL=true
NODE_NAME=${HOSTNAME}
NODE_ID=

# Central Hub URL (diisi oleh Windows Node untuk registrasi)
CENTRAL_HUB_URL=http://192.168.1.50:3000

# Shared Secret (HARUS SAMA di Ubuntu dan semua Windows Node)
NODE_SECRET=rahasia-perusahaan-anda-ganti-dengan-secret-yang-aman

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://printserver:printserver@localhost:5432/printserver

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_PATH=./storage
STORAGE_DRIVER=local

# S3 (optional)
S3_BUCKET=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Virtual Printer
PRINT_SPOOL_DIR=C:\PrintServer\Spool
VIRTUAL_PRINTER_ENABLED=true

# Queue
QUEUE_CONCURRENCY=5
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=5000

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# Security
RATE_LIMIT_MAX=100
RATE_LIMIT_TTL=60000
BODY_LIMIT=104857600

# Auto-Heal (Central Hub only)
AUTO_HEAL=true
CHECK_INTERVAL=30
HEAL_DELAY=60

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=printserver@company.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=