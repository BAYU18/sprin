{
  "name": "@printserver/client",
  "version": "1.0.0",
  "description": "PrintServer Client Agent",
  "author": "PrintServer",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "npx tsc --skipLibCheck --esModuleInterop; npx electron-builder --win --x64 --dir",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "socket.io-client": "^4.7.4",
    "axios": "^1.6.8",
    "chokidar": "^3.6.0",
    "uuid": "^9.0.1",
    "electron-log": "^5.1.1",
    "form-data": "^4.0.0",
    "tmp": "^0.2.3"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8"
  },
  "build": {
    "appId": "com.printserver.client",
    "productName": "PrintServer Client",
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "build/**/*"
    ]
  }
}